# 数据库配置
# SQLite 数据库文件路径（开发环境）
DATABASE_URL="file:./dev.db"

# JWT 密钥
# ⚠️ 生产环境请务必使用强随机密钥！可以使用以下命令生成：
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# 服务器端口
PORT=8080

# 运行环境
NODE_ENV=development

# CORS 允许的前端地址（支持多个域名，用逗号分隔）
# 开发环境示例：
# CORS_ORIGIN="http://localhost:3000"
# 生产环境示例（单个域名）：
# CORS_ORIGIN="https://sick-yeah.vercel.app"
# 同时支持多个域名：
# CORS_ORIGIN="http://localhost:3000,https://sick-yeah.vercel.app,https://your-domain.com"
CORS_ORIGIN="http://localhost:3000"
